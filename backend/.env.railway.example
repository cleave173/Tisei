# Railway production environment
# Paste into Railway -> Service -> Variables -> Raw Editor and replace placeholders.

DATABASE_URL=${{Postgres.DATABASE_URL}}
JWT_SECRET=replace-with-a-long-random-secret
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-flash-lite-latest
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id
CORS_ORIGINS=["*"]

# Password reset email.
# Gmail API uses HTTPS and avoids blocked SMTP ports on Railway.
EMAIL_BACKEND=gmail_api
GMAIL_CLIENT_ID=replace-with-your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=replace-with-your-gmail-oauth-client-secret
GMAIL_REFRESH_TOKEN=replace-with-your-gmail-refresh-token
GMAIL_FROM=replace-with-your-sender-gmail-address
