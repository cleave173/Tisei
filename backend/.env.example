POSTGRES_USER=tisei
POSTGRES_PASSWORD=tisei
POSTGRES_DB=tisei
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JWT_SECRET=please-change-me
GOOGLE_CLIENT_ID=
RESET_CODE_EXPIRE_MINUTES=15
# Dev/debug only: prints reset OTPs to deploy logs.
LOG_RESET_CODES=false

EMAIL_BACKEND=console
# SMTP option. On Railway, Gmail SMTP ports can time out; prefer a provider
# that supports port 2525, or use EMAIL_BACKEND=resend below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tisei.app
SMTP_TLS=true
SMTP_TIMEOUT_SECONDS=10

# HTTP email option.
# EMAIL_BACKEND=resend
# RESEND_API_KEY=

LIBRETRANSLATE_URL=http://localhost:5000

# Yandex Translate API (used for bulk vocabulary import: EN -> KK)
# Get an API key + folder_id at https://console.cloud.yandex.ru
YANDEX_TRANSLATE_API_KEY=
YANDEX_FOLDER_ID=
